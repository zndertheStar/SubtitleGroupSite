# 复制为 .env 并填写你的配置

# Umami 统计
UMAMI_WEBSITE_ID=your-website-id
UMAMI_SCRIPT_URL=https://your-umami-domain.com/script.js

# Giscus 评论
GISCUS_REPO=green-tea-subs/green-tea-subs-site
GISCUS_REPO_ID=
GISCUS_CATEGORY_ID=

# 字幕仓库（用于下载系统）
SUBTITLE_REPO=green-tea-subs/subtitles
SUBTITLE_REPO_BRANCH=main

# RSS 解析（展示板用）
RSS_FEED_URL=https://api.animes.garden/feed.xml
GROUP_NAME=绿茶字幕组

# Decap CMS（如果使用 Netlify Identity）
NETLIFY_IDENTITY_URL=
