# 复制为 .env 并填写你的配置

# Umami 统计
UMAMI_WEBSITE_ID=your-website-id
UMAMI_SCRIPT_URL=https://your-umami-domain.com/script.js

# Giscus 评论
GISCUS_REPO=your-username/your-repo
GISCUS_REPO_ID=
GISCUS_CATEGORY_ID=

# 字幕仓库（用于下载系统）
SUBTITLE_REPO=your-username/subtitles
SUBTITLE_REPO_BRANCH=main

# TMDB API（自动发布作品用，可选但推荐）
# 用于自动获取作品封面、简介、标签
# 申请地址：https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

