---
import { useTranslations } from '../i18n/ui';
import { siteConfig, getSiteName } from '../config/site';

interface Props {
  lang?: string;
}

const { lang = 'zh' } = Astro.props;
const t = useTranslations(lang as any);
const siteName = getSiteName(lang);

const navLinks = [
  { href: `/${lang === 'zh' ? '' : lang + '/'}`, label: t('nav.home') },
  { href: `/${lang === 'zh' ? '' : lang + '/'}works`, label: t('nav.works') },
  { href: `/${lang === 'zh' ? '' : lang + '/'}showcase`, label: t('nav.showcase') },
  { href: `/${lang === 'zh' ? '' : lang + '/'}misc`, label: t('nav.misc') },
  { href: `/${lang === 'zh' ? '' : lang + '/'}about`, label: t('nav.about') },
];

const languages = [
  { code: 'zh', label: '中文' },
  { code: 'ja', label: '日本語' },
  { code: 'en', label: 'EN' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-xl border-b transition-colors duration-300 header-blur">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${lang === 'zh' ? '' : lang + '/'}`} class="flex items-center gap-2 group">
        {siteConfig.logo.image ? (
          <img src={siteConfig.logo.image} alt={siteName} class="w-8 h-8 rounded-lg group-hover:scale-110 transition-transform" />
        ) : (
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-sm group-hover:scale-110 transition-transform glow-purple">
            {siteConfig.logo.iconText}
          </div>
        )}
        <span class="font-bold text-lg gradient-text hidden sm:block">{siteName}</span>
      </a>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a 
            href={link.href}
            class="nav-link px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right section -->
      <div class="flex items-center gap-3">
      <!-- Pagefind Search UI -->
      <div class="relative hidden sm:block" id="search-wrapper">
        <div id="search" class="pagefind-search" data-pagefind-ui></div>
      </div>

      <!-- Search Modal Button (Mobile) -->
      <button id="search-toggle" class="sm:hidden p-2 rounded-lg hover:bg-purple-500/10 transition-colors text-muted">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

        <!-- Language switcher -->
        <div class="relative group">
          <button class="px-2 py-1 rounded-lg text-sm font-medium text-muted hover:bg-purple-500/10 transition-colors">
            {languages.find(l => l.code === lang)?.label || '中文'}
          </button>
          <div class="absolute right-0 top-full mt-1 w-24 rounded-lg border shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden bg-surface border-theme">
            {languages.map(l => (
              <a 
                href={`/${l.code === 'zh' ? '' : l.code + '/'}${Astro.url.pathname.split('/').slice(2).join('/')}`}
                class="block px-4 py-2 text-sm text-muted hover:bg-purple-500/10 hover:text-purple-500 transition-colors"
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Dark mode toggle -->
        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-purple-500/10 transition-colors text-muted">
          <svg id="moon-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <svg id="sun-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>

        <!-- User Auth -->
        <div class="relative" id="user-menu-wrapper">
          <button id="user-menu-btn" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-purple-500/10 transition-colors">
            <div id="user-avatar" class="w-7 h-7 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-xs font-bold">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
          </button>
          
          <!-- User Dropdown -->
          <div id="user-dropdown" class="absolute right-0 top-full mt-2 w-48 rounded-xl border shadow-xl opacity-0 invisible transition-all duration-200 overflow-hidden bg-surface border-theme z-50">
            <div id="user-guest" class="p-3">
              <p class="text-sm text-gray-400 mb-2 px-2">未登录</p>
              <button id="btn-login" class="w-full text-left px-3 py-2 rounded-lg text-sm text-purple-400 hover:bg-purple-500/10 transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub 登录
              </button>
            </div>
            <div id="user-logged" class="hidden">
              <div class="p-3 border-b border-white/5">
                <p id="user-name" class="text-sm font-medium px-2"></p>
                <p id="user-email" class="text-xs text-gray-500 px-2 mt-0.5"></p>
              </div>
              <div class="p-2">
                <a href="/profile" class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-purple-500/10 hover:text-purple-500 transition-colors">
                  个人资料
                </a>
                <button id="btn-logout" class="w-full text-left px-3 py-2 rounded-lg text-sm text-red-400 hover:bg-red-500/10 transition-colors">
                  退出登录
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="md:hidden flex overflow-x-auto px-4 pb-2 gap-2">
    {navLinks.map(link => (
      <a 
        href={link.href}
        class="px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap bg-white/5 text-muted hover:bg-purple-500/20"
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<!-- Pagefind Search Script -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js" type="module" is:inline></script>
<script type="module" is:inline>
  async function initPagefind() {
    try {
      const pagefind = await import('/pagefind/pagefind-ui.js');
      const searchContainer = document.getElementById('search');
      if (searchContainer && pagefind.PagefindUI) {
        new pagefind.PagefindUI({
          element: '#search',
          showImages: false,
          showSubResults: true,
          translations: {
            placeholder: '搜索作品...',
            clear_search: '清除',
            load_more: '加载更多结果',
            search_label: '搜索',
            filters_label: '筛选',
            zero_results: '未找到 [SEARCH_TERM] 的相关结果',
            many_results: '[COUNT] 个结果',
            one_result: '1 个结果',
            alt_search: '未找到 [SEARCH_TERM] 的结果。显示 [DIFFERENT_TERM] 的相关结果',
            search_suggestion: '未找到 [SEARCH_TERM] 的结果。尝试以下搜索：',
            searching: '搜索中...'
          }
        });
      }
    } catch (e) {
      console.log('Pagefind UI init error:', e);
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPagefind);
  } else {
    initPagefind();
  }
  
  // Mobile search toggle
  const searchToggle = document.getElementById('search-toggle');
  const searchWrapper = document.getElementById('search-wrapper');
  searchToggle?.addEventListener('click', () => {
    searchWrapper?.classList.toggle('hidden');
    searchWrapper?.classList.toggle('absolute');
    searchWrapper?.classList.toggle('top-full');
    searchWrapper?.classList.toggle('left-0');
    searchWrapper?.classList.toggle('right-0');
    searchWrapper?.classList.toggle('mt-2');
    searchWrapper?.classList.toggle('bg-surface');
    searchWrapper?.classList.toggle('p-4');
    searchWrapper?.classList.toggle('rounded-xl');
    searchWrapper?.classList.toggle('border');
    searchWrapper?.classList.toggle('border-theme');
    searchWrapper?.classList.toggle('shadow-xl');
    searchWrapper?.classList.toggle('z-50');
  });
</script>

<!-- Netlify Identity -->
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>

<script is:inline>
  // User Auth Logic
  (function() {
    const userMenuBtn = document.getElementById('user-menu-btn');
    const userDropdown = document.getElementById('user-dropdown');
    const btnLogin = document.getElementById('btn-login');
    const btnLogout = document.getElementById('btn-logout');
    const userGuest = document.getElementById('user-guest');
    const userLogged = document.getElementById('user-logged');
    const userName = document.getElementById('user-name');
    const userEmail = document.getElementById('user-email');
    const userAvatar = document.getElementById('user-avatar');

    let isDropdownOpen = false;

    function toggleDropdown() {
      isDropdownOpen = !isDropdownOpen;
      if (isDropdownOpen) {
        userDropdown.classList.remove('opacity-0', 'invisible');
        userDropdown.classList.add('opacity-100', 'visible');
      } else {
        userDropdown.classList.add('opacity-0', 'invisible');
        userDropdown.classList.remove('opacity-100', 'visible');
      }
    }

    userMenuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleDropdown();
    });

    document.addEventListener('click', () => {
      if (isDropdownOpen) {
        toggleDropdown();
      }
    });

    // Check Netlify Identity user
    function updateUserUI() {
      // Check Netlify Identity user
      const user = netlifyIdentity?.currentUser();
      
      if (user) {
        userGuest?.classList.add('hidden');
        userLogged?.classList.remove('hidden');
        userName.textContent = user.user_metadata?.full_name || user.email?.split('@')[0] || '用户';
        userEmail.textContent = user.email || '';
        
        // Update avatar
        if (user.user_metadata?.avatar_url) {
          userAvatar.innerHTML = `<img src="${user.user_metadata.avatar_url}" class="w-7 h-7 rounded-full object-cover" />`;
        } else {
          const initial = (user.user_metadata?.full_name || user.email || 'U')[0].toUpperCase();
          userAvatar.innerHTML = `<span class="text-xs font-bold">${initial}</span>`;
        }
      } else {
        userGuest?.classList.remove('hidden');
        userLogged?.classList.add('hidden');
        userAvatar.innerHTML = `
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        `;
      }
    }

    btnLogin?.addEventListener('click', () => {
      netlifyIdentity?.open('login');
    });

    btnLogout?.addEventListener('click', () => {
      netlifyIdentity?.logout();
    });

    // Listen for auth events
    if (window.netlifyIdentity) {
      netlifyIdentity.on('init', updateUserUI);
      netlifyIdentity.on('login', updateUserUI);
      netlifyIdentity.on('logout', updateUserUI);
    }

    // Fallback: check after a delay
    setTimeout(updateUserUI, 1000);
  })();

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const moonIcon = document.getElementById('moon-icon');
  const sunIcon = document.getElementById('sun-icon');

  function updateIcon() {
    const theme = document.documentElement.getAttribute('data-theme');
    if (theme === 'dark') {
      moonIcon?.classList.remove('hidden');
      sunIcon?.classList.add('hidden');
    } else {
      moonIcon?.classList.add('hidden');
      sunIcon?.classList.remove('hidden');
    }
  }

  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateIcon();
  });

  updateIcon();
</script>
