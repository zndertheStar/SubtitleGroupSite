---
import { useTranslations } from '../i18n/ui';
import { siteConfig, getSiteName } from '../config/site';
import { friendLinks } from '../config/friends';

interface Props {
  lang?: string;
}

const { lang = 'zh' } = Astro.props;
const t = useTranslations(lang as any);
const siteName = getSiteName(lang);
---

<footer class="mt-auto py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Left: Site Stats - 液态玻璃遮罩 -->
      <div class="glass-nav-item">
        {siteConfig.logo.image ? (
          <img src={siteConfig.logo.image} alt={siteName} class="w-7 h-7 rounded-lg flex-shrink-0" />
        ) : (
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">
            {siteConfig.logo.iconText}
          </div>
        )}
        <span class="text-muted text-sm">{siteName}</span>
        <span class="text-gray-600">|</span>
        <!-- Umami Stats -->
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span id="umami-stats">统计加载中...</span>
        </div>
      </div>

      <!-- Right: Friend Links - 液态玻璃遮罩 -->
      <div class="glass-nav-item">
        {friendLinks.length > 0 ? (
          <div class="flex items-center gap-3">
            <span class="text-gray-500">友站:</span>
            {friendLinks.map(link => (
              <a 
                href={link.url} 
                target="_blank" 
                rel="noopener" 
                class="text-gray-400 hover:text-primary-400 transition-colors"
                title={link.description}
              >
                {link.name}
              </a>
            ))}
            <a href="/friends" class="text-primary-500 hover:text-primary-400 transition-colors">更多 →</a>
          </div>
        ) : (
          <a href="/friends" class="text-gray-500 hover:text-primary-400 transition-colors">友站链接</a>
        )}
      </div>
    </div>
  </div>
  
  <!-- Umami Stats Script -->
  <script is:inline>
    (function() {
      const statsEl = document.getElementById('umami-stats');
      
      // 尝试从 Umami API 获取统计
      // 需要用户配置自己的 Umami API
      async function fetchStats() {
        try {
          // 这里使用 umami 的 API（如果用户配置了）
          // 实际使用时需要替换为真实的 Umami API endpoint
          const response = await fetch('/api/stats');
          if (response.ok) {
            const data = await response.json();
            if (data && data.visits) {
              statsEl.textContent = `${data.visits.toLocaleString()} 次访问`;
              return;
            }
          }
        } catch (e) {
          // 静默失败，显示备用信息
        }
        
        // 备用：显示本地计数或使用 cookie 计数
        let visitCount = parseInt(localStorage.getItem('site_visit_count') || '0');
        if (!sessionStorage.getItem('visited_this_session')) {
          visitCount++;
          localStorage.setItem('site_visit_count', visitCount.toString());
          sessionStorage.setItem('visited_this_session', 'true');
        }
        statsEl.textContent = `${visitCount.toLocaleString()} 次访问`;
      }
      
      fetchStats();
    })();
  </script>
</footer>
