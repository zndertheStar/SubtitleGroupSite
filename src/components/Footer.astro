---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang?: string;
}

const { lang = 'zh' } = Astro.props;
const t = useTranslations(lang as any);
---

<footer class="mt-auto border-t py-8 transition-colors duration-300 bg-surface border-theme">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Logo & Copyright -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-sm">
          G
        </div>
        <span class="text-sm text-muted">{t('footer.copyright')}</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-muted">
        <a href="https://github.com/green-tea-subs" target="_blank" rel="noopener" class="hover:text-purple-500 transition-colors flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="/admin" class="hover:text-purple-500 transition-colors">管理后台</a>
        <a href="/rss.xml" class="hover:text-purple-500 transition-colors">RSS</a>
      </div>
    </div>
  </div>
</footer>
