---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageLoader from '../../components/PageLoader.astro';
import { getCollection } from 'astro:content';

const lang = 'zh';
const miscPosts = await getCollection('misc');
const posts = miscPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="杂谈" lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold mb-2">杂谈</h1>
        <p class="text-gray-400">组内日常与非作品类内容</p>
      </div>

      <div class="space-y-4">
        {posts.map(post => (
          <a href={`/misc/${post.slug}`} class="anime-card block p-5 group transition-all hover:bg-white/[0.08]">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg glass bg-blue-500/10 flex items-center justify-center flex-shrink-0 text-lg">
                📝
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <div class="flex-1 min-w-0">
                    <h2 class="text-lg font-semibold group-hover:text-purple-300 transition-colors line-clamp-1">{post.data.title}</h2>
                    {post.data.description && (
                      <p class="text-gray-500 mt-1 text-sm line-clamp-2">{post.data.description}</p>
                    )}
                  </div>
                  <span class="text-xs text-gray-500 flex-shrink-0 mt-1">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
                </div>
                
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {post.data.tags.map(tag => (
                      <span class="px-2 py-0.5 rounded-full text-[10px] glass-badge text-gray-400">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
