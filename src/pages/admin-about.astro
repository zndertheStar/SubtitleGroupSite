---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'zh';
---

<Layout title="关于页面" description="编辑关于页面" lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-1">关于页面</h1>
          <p class="text-sm text-gray-400">编辑关于我们页面</p>
        </div>
        <a href="/admin-dashboard" class="text-sm text-purple-400 hover:text-purple-300">← 返回管理后台</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1 space-y-4">
          <div class="anime-card p-4">
            <h3 class="font-semibold mb-3">文件路径</h3>
            <div class="text-sm text-gray-400 space-y-1">
              <p>关于页面位置：</p>
              <code class="block bg-white/5 p-2 rounded text-xs">src/content/about/index.md</code>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="anime-card p-4">
            <div class="flex items-center justify-between mb-4">
              <label class="text-sm font-medium">关于页面模板</label>
              <button id="btn-copy" class="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                复制
              </button>
            </div>
            <textarea 
              id="template-editor" 
              class="w-full h-[400px] px-3 py-2 rounded-lg border border-white/10 bg-white/5 text-sm font-mono focus:outline-none focus:border-purple-500/50 resize-none"
              readonly
            >---
title: "关于我们"
description: "站点简介"
---

## 关于我们

欢迎来到我们的站点！

## 团队介绍

我们是一个热爱动漫的字幕组...

## 联系方式

- 邮箱：example@example.com
- QQ群：123456789

## 加入我们

如果你热爱动漫，欢迎加入！
</textarea>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    document.getElementById('btn-copy')?.addEventListener('click', () => {
      const editor = document.getElementById('template-editor');
      navigator.clipboard.writeText(editor.value).then(() => {
        const btn = document.getElementById('btn-copy');
        btn.textContent = '已复制';
        setTimeout(() => {
          btn.innerHTML = `
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            复制
          `;
        }, 2000);
      });
    });
  </script>

  <Footer lang={lang} />
</Layout>
