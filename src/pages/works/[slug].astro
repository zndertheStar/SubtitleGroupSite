---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DownloadButton from '../../components/DownloadButton.svelte';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/ui';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map(work => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const lang = 'zh';
const t = useTranslations(lang);

// Auto-detect downloads from subtitle repo
// In real implementation, this would read from the subtitle repo manifest
const downloads = [
  // Example structure - would be populated by build script
  { name: work.data.title + ' - 字幕文件', url: '#', size: '2.3 MB', type: 'subtitles' as const, note: '' },
  { name: work.data.title + ' - 字体包', url: '#', size: '15 MB', type: 'fonts' as const, note: '' },
];
---

<Layout title={work.data.title} description={work.data.description} lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Article Header -->
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-4 flex-wrap">
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-purple-500/20 text-purple-400">
            {work.data.category === 'anime' ? '动画' : work.data.category === 'movie' ? '电影' : work.data.category === 'ova' ? 'OVA' : '其他'}
          </span>
          {work.data.season && (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-pink-500/20 text-pink-400">
              {work.data.season}
            </span>
          )}
          {work.data.episode && (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-500/20 text-blue-400">
              第{work.data.episode}集
            </span>
          )}
        </div>
        
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-theme">{work.data.title}</h1>
        
        <div class="flex items-center gap-4 text-sm text-muted mb-6">
          <span>{work.data.pubDate.toLocaleDateString('zh-CN')}</span>
          {work.data.source && <span>片源: {work.data.source}</span>}
        </div>

        {work.data.cover && (
          <div class="aspect-video rounded-2xl overflow-hidden mb-8">
            <img src={work.data.cover} alt={work.data.title} class="w-full h-full object-cover" />
          </div>
        )}
      </div>

      <!-- Article Content -->
      <article class="prose-custom max-w-none mb-12">
        <Content />
      </article>

      <!-- Tags -->
      {work.data.tags.length > 0 && (
        <div class="flex items-center gap-2 mb-8 flex-wrap">
          <span class="text-sm text-muted">标签:</span>
          {work.data.tags.map(tag => (
            <span class="px-3 py-1 rounded-full text-sm bg-purple-500/10 text-purple-400 border border-purple-500/20">{tag}</span>
          ))}
        </div>
      )}

      <!-- Downloads Section -->
      <section class="rounded-2xl border p-6 mb-12 border-theme bg-surface">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-theme">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {t('download.title')}
        </h2>
        
        <div class="space-y-3">
          {downloads.map(download => (
            <DownloadButton 
              client:load
              url={download.url}
              filename={download.name}
              size={download.size}
              type={download.type}
              note={download.note}
            />
          ))}
        </div>
        
        <p class="text-xs text-muted mt-4">
          字幕文件需配合对应片源使用。如链接失效，请在评论区反馈。
        </p>
      </section>

      <!-- Giscus Comments -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-4 text-theme">{t('giscus.title')}</h2>
        <div class="rounded-2xl border p-4 border-theme bg-surface/50">
          <div class="giscus"></div>
          <script src="https://giscus.app/client.js"
            data-repo={import.meta.env.GISCUS_REPO || "your-username/your-repo"}
            data-repo-id={import.meta.env.GISCUS_REPO_ID || ""}
            data-category="Comments"
            data-category-id={import.meta.env.GISCUS_CATEGORY_ID || ""}
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="transparent_dark"
            data-lang="zh-CN"
            crossorigin="anonymous"
            async>
          </script>
        </div>
      </section>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
