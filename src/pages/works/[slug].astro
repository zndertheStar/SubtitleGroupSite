---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DownloadButton from '../../components/DownloadButton.svelte';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/ui';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map(work => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const lang = 'zh';
const t = useTranslations(lang);

// Build downloads from versions magnet links
const downloads = work.data.versions?.map(v => ({
  name: v.name,
  url: v.magnet,
  size: '',
  type: 'subtitles' as const,
  note: 'Magnet 链接'
})) || [];

const data = work.data;

// Format helpers
const formatDate = (dateStr: string | undefined) => {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('zh-CN');
};

const formatRuntime = (minutes: number | undefined) => {
  if (!minutes) return '';
  return `${minutes} minutes`;
};

const formatRating = (rating: number | undefined) => {
  if (!rating) return '';
  return `${rating} / 10`;
};

const formatList = (arr: string[] | undefined, separator = ' / ') => {
  if (!arr || arr.length === 0) return '';
  return arr.join(separator);
};

const producers = data.crew?.filter(c => 
  c.job === 'Producer' || c.job === 'Executive Producer'
).map(c => c.name) || [];
---

<Layout title={data.title} description={data.description} lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- PT Style Header with Poster -->
      <div class="flex flex-col md:flex-row gap-8 mb-10">
        <!-- Poster -->
        <div class="md:w-72 flex-shrink-0">
          {data.cover && (
            <div class="rounded-xl overflow-hidden shadow-2xl border border-white/10">
              <img 
                src={data.cover} 
                alt={data.title} 
                class="w-full aspect-[2/3] object-cover"
              />
            </div>
          )}
        </div>
        
        <!-- Info Panel -->
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <span class="glass-badge text-purple-300 text-base px-3 py-1">
              {data.category === 'anime' ? '动画' : data.category === 'movie' ? '电影' : data.category === 'ova' ? 'OVA' : '其他'}
            </span>
            {data.episode && (
              <span class="glass-badge text-blue-300 text-base px-3 py-1">
                第{data.episode}集
              </span>
            )}
          </div>
          
          <h1 class="text-3xl sm:text-4xl font-bold mb-2 text-theme">{data.title}</h1>
          
          {data.originalTitle && data.originalTitle !== data.title && (
            <p class="text-lg text-muted mb-4">{data.originalTitle}</p>
          )}
          
          <!-- PT Info List -->
          <div class="space-y-1.5 text-sm mt-6">
            {data.genres && data.genres.length > 0 && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Genres:</span>
                <span class="text-muted">{formatList(data.genres, ' / ')}</span>
              </div>
            )}
            
            {data.language && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Languages:</span>
                <span class="text-muted">{data.language}</span>
              </div>
            )}
            
            {data.firstAirDate && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ First Air Date:</span>
                <span class="text-muted">{formatDate(data.firstAirDate)}</span>
              </div>
            )}
            
            {data.numberOfEpisodes && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Number of Episodes:</span>
                <span class="text-muted">{data.numberOfEpisodes}</span>
              </div>
            )}
            
            {data.numberOfSeasons && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Number of Seasons:</span>
                <span class="text-muted">{data.numberOfSeasons}</span>
              </div>
            )}
            
            {data.episodeRuntime && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Episode Runtime:</span>
                <span class="text-muted">{formatRuntime(data.episodeRuntime)}</span>
              </div>
            )}
            
            {data.productionCountries && data.productionCountries.length > 0 && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Production Countries:</span>
                <span class="text-muted">{formatList(data.productionCountries)}</span>
              </div>
            )}
            
            {data.rating && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Rating:</span>
                <span class="text-muted">{formatRating(data.rating)}</span>
              </div>
            )}
            
            {data.tmdbUrl && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ TMDB Link:</span>
                <a href={data.tmdbUrl} target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300 transition-colors">
                  {data.tmdbUrl}
                </a>
              </div>
            )}
            
            {data.imdbId && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ IMDb Link:</span>
                <a href={`https://www.imdb.com/title/${data.imdbId}/`} target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300 transition-colors">
                  https://www.imdb.com/title/{data.imdbId}/
                </a>
              </div>
            )}
            
            {producers.length > 0 && (
              <div class="flex gap-2">
                <span class="text-purple-400 font-medium min-w-[120px]">❁ Producers:</span>
                <span class="text-muted">{formatList(producers, ' / ')}</span>
              </div>
            )}
          </div>
          
          <!-- Tags -->
          {data.tags.length > 0 && (
            <div class="flex items-center gap-2 mt-4 flex-wrap">
              {data.tags.map(tag => (
                <span class="glass-badge text-purple-300 text-sm px-3 py-1">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
      
      <!-- Cast Section -->
      {data.cast && data.cast.length > 0 && (
        <section class="anime-card p-6 mb-8">
          <h2 class="text-xl font-bold mb-4 text-purple-400 flex items-center gap-2">
            <span>❁</span> Cast
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {data.cast.map(actor => (
              <div class="flex items-center gap-3 p-3 rounded-lg bg-white/5">
                {actor.profilePath ? (
                  <img 
                    src={`https://image.tmdb.org/t/p/w45${actor.profilePath}`} 
                    alt={actor.name}
                    class="w-10 h-10 rounded-full object-cover"
                  />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center text-sm">
                    {actor.name.charAt(0)}
                  </div>
                )}
                <div class="min-w-0">
                  <div class="text-sm font-medium truncate">{actor.name}</div>
                  {actor.character && (
                    <div class="text-xs text-gray-500 truncate">as {actor.character}</div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}
      
      <!-- Introduction -->
      {data.description && (
        <section class="anime-card p-6 mb-8">
          <h2 class="text-xl font-bold mb-4 text-purple-400 flex items-center gap-2">
            <span>❁</span> Introduction
          </h2>
          <div class="prose-custom max-w-none leading-relaxed">
            <p>{data.description}</p>
          </div>
        </section>
      )}
      
      <!-- Markdown Content (if any) -->
      <article class="prose-custom max-w-none mb-8">
        <Content />
      </article>
      
      <!-- Downloads Section -->
      <section class="anime-card p-6 mb-12">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-theme">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {t('download.title')}
        </h2>
        
        <div class="space-y-3">
          {downloads.map(download => (
            <DownloadButton 
              client:load
              url={download.url}
              filename={download.name}
              size={download.size}
              type={download.type}
              note={download.note}
            />
          ))}
        </div>
        
        <p class="text-xs text-muted mt-4">
          字幕文件需配合对应片源使用。如链接失效，请在评论区反馈。
        </p>
      </section>
      
      <!-- Giscus Comments -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-4 text-theme">{t('giscus.title')}</h2>
        <div class="anime-card p-4">
          <div class="giscus"></div>
          <script src="https://giscus.app/client.js"
            data-repo={import.meta.env.GISCUS_REPO}
            data-repo-id={import.meta.env.GISCUS_REPO_ID}
            data-category="Comments"
            data-category-id={import.meta.env.GISCUS_CATEGORY_ID}
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="transparent_dark"
            data-lang="zh-CN"
            crossorigin="anonymous"
            async>
          </script>
        </div>
      </section>
    </div>
  </main>
  
  <Footer lang={lang} />
</Layout>