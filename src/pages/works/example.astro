---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageLoader from '../../components/PageLoader.astro';
import AntiSpamNotice from '../../components/AntiSpamNotice.astro';
import { siteConfig } from '../../config/site';
import { isSpam, filterComments } from '../../config/anti-spam';

const lang = 'zh';

// 模拟作品数据
const work = {
  title: '某新番 第01集',
  description: '绿茶字幕组出品，某新番第01集简体中文字幕版。',
  category: 'anime',
  season: '2025春',
  episode: 1,
  source: 'Baha',
  pubDate: new Date('2025-04-15'),
  tags: ['新番', '2025春', '校园'],
  cover: '',
};

// 模拟评论区数据（包含正常评论和垃圾评论）
const allComments = [
  {
    id: 1,
    author: '动漫爱好者',
    avatar: '👤',
    date: '2025-04-15',
    content: '翻译质量很好！感谢字幕组的付出！',
    reactions: { thumbsUp: 12, heart: 5 },
    replies: [
      {
        id: 11,
        author: '字幕组成员',
        avatar: '🟢',
        date: '2025-04-15',
        content: '谢谢支持！我们会继续努力的！',
        reactions: { thumbsUp: 3 },
      }
    ]
  },
  {
    id: 2,
    author: '追番党',
    avatar: '👤',
    date: '2025-04-16',
    content: '字体大小很合适，看得很舒服。期待第2集！',
    reactions: { thumbsUp: 8, heart: 2 },
    replies: []
  },
  {
    id: 3,
    author: '技术宅',
    avatar: '👤',
    date: '2025-04-16',
    content: '压制质量不错，文件大小控制得很好。字幕时间轴也很准确。',
    reactions: { thumbsUp: 6 },
    replies: [
      {
        id: 31,
        author: '后期组',
        avatar: '🟢',
        date: '2025-04-16',
        content: '感谢反馈！我们使用了新的压制参数，会继续优化。',
        reactions: { thumbsUp: 2, heart: 1 },
      }
    ]
  },
  // 垃圾评论示例（将被过滤）
  {
    id: 4,
    author: '广告机器人',
    avatar: '🤖',
    date: '2025-04-16',
    content: '加微信 xxxxxx 领取免费资源，还有各种优惠券！',
    reactions: {},
    replies: [],
    isSpam: true,
  },
  {
    id: 5,
    author: '骗子小号',
    avatar: '🤖',
    date: '2025-04-17',
    content: '轻松赚钱，日入500+，详情请咨询QQ 123456789',
    reactions: {},
    replies: [],
    isSpam: true,
  },
];

// 使用反垃圾系统过滤评论
const mockComments = allComments.filter(comment => !isSpam(comment.content));
const spamComments = allComments.filter(comment => isSpam(comment.content));
---

<Layout title={work.title} description={work.description} lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Article Header -->
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-4 flex-wrap">
          <span class="glass-badge text-purple-400">动画</span>
          <span class="glass-badge text-pink-400">{work.season}</span>
          <span class="glass-badge text-blue-400">第{work.episode}集</span>
        </div>
        
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-theme">{work.title}</h1>
        
        <div class="flex items-center gap-4 text-sm text-muted mb-6">
          <span>{work.pubDate.toLocaleDateString('zh-CN')}</span>
          <span>片源: {work.source}</span>
        </div>

        <!-- Cover Placeholder -->
        <div class="aspect-video rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-purple-900/50 to-pink-900/50 flex items-center justify-center">
          <span class="text-6xl">🎬</span>
        </div>
      </div>

      <!-- Article Content -->
      <article class="prose-custom max-w-none mb-12">
        <h2>作品简介</h2>
        <p>这是本季备受期待的校园动画，讲述了一段温暖人心的青春故事。</p>
        
        <h2>STAFF</h2>
        <ul>
          <li>翻译：张三</li>
          <li>校对：李四</li>
          <li>后期：王五</li>
          <li>压制：赵六</li>
        </ul>
        
        <h2>片源信息</h2>
        <ul>
          <li>片源：巴哈姆特 (Baha)</li>
          <li>分辨率：1080p</li>
          <li>音频：AAC</li>
        </ul>
        
        <h2>注意事项</h2>
        <ol>
          <li>本字幕仅供学习交流使用</li>
          <li>请支持正版</li>
          <li>如有问题请在评论区留言</li>
        </ol>
      </article>

      <!-- Tags -->
      <div class="flex items-center gap-2 mb-8 flex-wrap">
        <span class="text-sm text-muted">标签:</span>
        {work.tags.map(tag => (
          <span class="glass-badge text-purple-300">{tag}</span>
        ))}
      </div>

      <!-- Downloads Section -->
      <section class="rounded-2xl border p-6 mb-12 border-theme bg-surface">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-theme">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          下载资源
        </h2>
        
        <div class="space-y-3">
          <div class="anime-card hover:border-purple-400/30 transition-colors group">
            <div class="flex items-center justify-between p-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg glass bg-purple-500/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div>
                  <div class="font-medium text-sm">{work.title} - 字幕文件</div>
                  <div class="text-xs text-muted">2.3 MB</div>
                </div>
              </div>
              <button class="px-4 py-2 rounded-lg glass text-purple-300 text-sm hover:border-purple-400/40 transition-colors">
                下载
              </button>
            </div>
          </div>
          
          <div class="anime-card hover:border-purple-400/30 transition-colors group">
            <div class="flex items-center justify-between p-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg glass bg-purple-500/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  </svg>
                </div>
                <div>
                  <div class="font-medium text-sm">{work.title} - 字体包</div>
                  <div class="text-xs text-muted">15 MB</div>
                </div>
              </div>
              <button class="px-4 py-2 rounded-lg glass text-purple-300 text-sm hover:border-purple-400/40 transition-colors">
                下载
              </button>
            </div>
          </div>
        </div>
        
        <p class="text-xs text-muted mt-4">字幕文件需配合对应片源使用。如链接失效，请在评论区反馈。</p>
      </section>

      <!-- Comments Section (Mock) -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-4 text-theme">评论区</h2>
        
        <!-- Anti-Spam Notice -->
        <AntiSpamNotice commentCount={allComments.length} />
        
        <!-- Spam Filtered Info -->
        {spamComments.length > 0 && (
          <div class="mb-4 p-3 rounded-xl glass border-yellow-400/20 flex items-center gap-2">
            <svg class="w-4 h-4 text-yellow-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="text-xs text-yellow-300">
              已自动过滤 {spamComments.length} 条垃圾评论（广告、欺诈内容）
            </span>
          </div>
        )}
        
        <!-- Giscus Info Banner -->
        <div class="mb-6 p-4 rounded-xl glass border-blue-400/20">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="text-sm text-blue-300">
              <p>评论区由 Giscus 驱动，基于 GitHub Discussions。配置后即可使用。</p>
              <p class="mt-1 text-xs text-blue-400/80">下方是评论区效果预览：</p>
            </div>
          </div>
        </div>
        
        <!-- Mock Comments -->
        <div class="anime-card p-6 space-y-6">
          <!-- Comment Count -->
          <div class="flex items-center justify-between border-b border-white/5 pb-4">
            <div class="flex items-center gap-2">
              <span class="text-sm text-muted">{mockComments.length} 条评论</span>
              {spamComments.length > 0 && (
                <span class="text-xs text-yellow-500/70">（已过滤 {spamComments.length} 条垃圾内容）</span>
              )}
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-muted">排序:</span>
              <select class="bg-transparent text-xs text-muted border border-white/10 rounded-lg px-2 py-1">
                <option>最新</option>
                <option>最早</option>
                <option>最多点赞</option>
              </select>
            </div>
          </div>
          
          <!-- Write Comment Box -->
          <div class="flex gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-lg flex-shrink-0">
              👤
            </div>
            <div class="flex-1">
              <div class="border border-white/10 rounded-xl p-3 bg-white/[0.03]">
                <textarea 
                  class="w-full bg-transparent text-sm resize-none outline-none placeholder-gray-500" 
                  rows="3" 
                  placeholder="写下你的评论..."
                  readonly
                ></textarea>
                <div class="flex items-center justify-between mt-2 pt-2 border-t border-white/5">
                  <div class="flex items-center gap-2">
                    <button class="text-gray-500 hover:text-purple-400 transition-colors">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </button>
                    <button class="text-gray-500 hover:text-purple-400 transition-colors">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </button>
                  </div>
                  <button class="px-4 py-1.5 rounded-lg glass text-purple-300 text-sm hover:border-purple-400/40 transition-colors opacity-50 cursor-not-allowed">
                    评论
                  </button>
                </div>
              </div>
              <p class="text-xs text-muted mt-2">请使用 GitHub 账号登录后发表评论</p>
            </div>
          </div>
          
          <!-- Comments List -->
          <div class="space-y-6">
            {mockComments.map(comment => (
              <div class="border-b border-white/5 last:border-0 pb-6 last:pb-0">
                <!-- Main Comment -->
                <div class="flex gap-3">
                  <div class="w-10 h-10 rounded-full glass bg-gray-500/20 flex items-center justify-center text-xl flex-shrink-0">
                    {comment.avatar}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="font-medium text-sm">{comment.author}</span>
                      <span class="text-xs text-muted">{comment.date}</span>
                    </div>
                    <div class="text-sm text-gray-300 mb-3 whitespace-pre-wrap">{comment.content}</div>
                    
                    <!-- Reactions -->
                    <div class="flex items-center gap-3">
                      {Object.entries(comment.reactions).map(([type, count]) => (
                        <button class="flex items-center gap-1 px-2 py-1 rounded-full glass text-xs text-muted hover:bg-purple-500/10 hover:text-purple-400 transition-colors">
                          <span>
                            {type === 'thumbsUp' ? '👍' : type === 'heart' ? '❤️' : '👎'}
                          </span>
                          <span>{count}</span>
                        </button>
                      ))}
                      <button class="text-xs text-muted hover:text-purple-400 transition-colors">
                        回复
                      </button>
                    </div>
                  </div>
                </div>
                
                <!-- Replies -->
                {comment.replies.length > 0 && (
                  <div class="mt-4 ml-13 pl-7 border-l-2 border-white/5 space-y-4">
                    {comment.replies.map(reply => (
                      <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full glass bg-purple-500/20 flex items-center justify-center text-sm flex-shrink-0">
                          {reply.avatar}
                        </div>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 mb-1">
                            <span class="font-medium text-sm text-purple-400">{reply.author}</span>
                            <span class="text-xs text-muted">{reply.date}</span>
                          </div>
                          <div class="text-sm text-gray-300 mb-2">{reply.content}</div>
                          
                          <div class="flex items-center gap-2">
                            {Object.entries(reply.reactions).map(([type, count]) => (
                              <button class="flex items-center gap-1 px-2 py-0.5 rounded-full glass text-xs text-muted hover:bg-purple-500/10 hover:text-purple-400 transition-colors">
                                <span>{type === 'thumbsUp' ? '👍' : '❤️'}</span>
                                <span>{count}</span>
                              </button>
                            ))}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
          
          <!-- Load More -->
          <div class="text-center pt-4">
            <button class="text-sm text-muted hover:text-purple-400 transition-colors">
              加载更多评论...
            </button>
          </div>
        </div>
        
        <!-- Real Giscus Integration Note -->
        <div class="mt-6 p-4 rounded-xl glass text-center">
          <p class="text-sm text-gray-400 mb-3">以上是评论区效果预览。配置 Giscus 后将显示真实评论。</p>
          <div class="flex items-center justify-center gap-4 text-xs text-gray-500">
            <span> powered by</span>
            <a href="https://giscus.app" target="_blank" class="text-purple-400 hover:underline">Giscus</a>
            <span>+</span>
            <a href="https://github.com" target="_blank" class="text-purple-400 hover:underline">GitHub Discussions</a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .ml-13 {
    margin-left: 3.25rem;
  }
</style>
