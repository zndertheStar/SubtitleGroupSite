---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'zh';
---

<Layout title="杂谈管理" description="管理杂谈文章" lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-1">杂谈管理</h1>
          <p class="text-sm text-gray-400">添加新杂谈或编辑现有杂谈</p>
        </div>
        <a href="/admin-dashboard" class="text-sm text-purple-400 hover:text-purple-300">← 返回管理后台</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Quick Actions -->
        <div class="lg:col-span-1 space-y-4">
          <div class="anime-card p-4">
            <h3 class="font-semibold mb-3">快速操作</h3>
            <div class="space-y-2">
              <a href="/admin-editor" class="block w-full px-4 py-2 rounded-lg glass text-purple-300 hover:border-purple-400/40 transition-all text-sm text-center">
                + 新建杂谈
              </a>
              <a href="/misc" target="_blank" class="block w-full px-4 py-2 rounded-lg glass text-gray-300 hover:bg-white/[0.08] transition-all text-sm text-center">
                查看杂谈页
              </a>
            </div>
          </div>

          <div class="anime-card p-4">
            <h3 class="font-semibold mb-3">文件路径</h3>
            <div class="text-sm text-gray-400 space-y-1">
              <p>杂谈存放位置：</p>
              <code class="block glass bg-white/[0.03] p-2 rounded text-xs">src/content/misc/</code>
            </div>
          </div>
        </div>

        <!-- Template -->
        <div class="lg:col-span-2">
          <div class="anime-card p-4">
            <div class="flex items-center justify-between mb-4">
              <label class="text-sm font-medium">杂谈模板</label>
              <button id="btn-copy" class="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                复制
              </button>
            </div>
            <textarea 
              id="template-editor" 
              class="w-full h-[400px] px-3 py-2 rounded-lg border border-white/10 bg-white/[0.03] text-sm font-mono focus:outline-none focus:border-purple-500/50 resize-none"
              readonly
            >---
title: "文章标题"
description: "文章简介"
pubDate: {new Date().toISOString().split('T')[0]}
tags: ["标签1", "标签2"]
lang: ["zh"]
---

# 文章标题

这里是文章内容...
</textarea>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    document.getElementById('btn-copy')?.addEventListener('click', () => {
      const editor = document.getElementById('template-editor');
      navigator.clipboard.writeText(editor.value).then(() => {
        const btn = document.getElementById('btn-copy');
        btn.textContent = '已复制';
        setTimeout(() => {
          btn.innerHTML = `
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            复制
          `;
        }, 2000);
      });
    });
  </script>

  <Footer lang={lang} />
</Layout>
