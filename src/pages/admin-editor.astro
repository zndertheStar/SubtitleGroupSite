---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'zh';

// 预定义的模板
const templates = {
  work: `---
title: "作品标题"
description: "作品简介"
cover: "/images/cover.jpg"
tags: ["标签1", "标签2"]
category: "anime"
pubDate: ${new Date().toISOString().split('T')[0]}
episode: 1
source: "Baha"
featured: false
season: "2025春"
lang: ["zh"]
---

# 作品标题

这里是作品的详细描述...

## 剧情简介

本作讲述了...

## STAFF

- **翻译**: 张三
- **校对**: 李四
- **后期**: 王五
- **压制**: 赵六

## 下载链接

| 类型 | 大小 | 链接 |
|------|------|------|
| 字幕文件 | 2.3 MB | [下载](#) |
| 字体包 | 15 MB | [下载](#) |

## 注意事项

1. 本字幕仅供学习交流使用
2. 请支持正版
3. 如有问题请在评论区留言

> 如果你有任何问题，可以通过以下方式联系我们。
`,
  misc: `---
title: "文章标题"
description: "文章简介"
pubDate: ${new Date().toISOString().split('T')[0]}
tags: ["标签1", "标签2"]
lang: ["zh"]
---

# 文章标题

这里是文章内容...

## 正文

这是一段普通的文字，包含**粗体**、*斜体*和~~删除线~~。

> 这是一段引用文字，可以用于引用他人的观点或重要的提示。

### 代码示例

\`\`\`javascript
// 这是一段代码示例
function hello() {
  console.log("Hello, World!");
}
\`\`\`

### 任务列表

- [x] 已完成任务
- [ ] 未完成任务
- [ ] 另一个未完成任务

### 链接和图片

[点击访问我们的网站](https://example.com)

![图片描述](/images/example.jpg)
`,
  showcase: `---
season: "2025春"
shows:
  - title: "番剧名称"
    regex: '番剧名称.*?(\\d+)'
    alsoIn: []
    versions:
      - name: "Baha"
        episodes: [1, 2, 3]
      - name: "CR"
        episodes: [1, 2]
---
`,
  about: `---
title: "关于我们"
description: "站点简介"
---

# 关于我们

欢迎来到我们的站点！

## 团队介绍

我们是一个热爱动漫的字幕组...

## 联系方式

- **邮箱**: example@example.com
- **QQ群**: 123456789

## 加入我们

如果你热爱动漫，欢迎加入！
`
};

const contentTypes = [
  { id: 'work', name: '作品', folder: 'src/content/works', template: templates.work },
  { id: 'misc', name: '杂谈', folder: 'src/content/misc', template: templates.misc },
  { id: 'showcase', name: '展示板', folder: 'src/content/showcase', template: templates.showcase },
  { id: 'about', name: '关于', folder: 'src/content/about', template: templates.about },
];
---

<Layout title="内容编辑器" description="Markdown 内容编辑器" lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-1">内容编辑器</h1>
          <p class="text-sm text-gray-400">Markdown 内容编辑器 - 支持实时预览</p>
        </div>
        <a href="/admin-dashboard" class="text-sm text-purple-400 hover:text-purple-300">← 返回管理后台</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Editor Section -->
        <div class="space-y-4">
          <!-- Content Type Selector -->
          <div class="anime-card p-4">
            <label class="block text-sm font-medium mb-2">内容类型</label>
            <select id="content-type" class="w-full px-3 py-2 rounded-lg border border-white/10 bg-white/5 text-sm focus:outline-none focus:border-purple-500/50">
              {contentTypes.map(type => (
                <option value={type.id} data-folder={type.folder}>{type.name} ({type.folder})</option>
              ))}
            </select>
          </div>

          <!-- Toolbar -->
          <div class="anime-card p-3 flex items-center gap-2 flex-wrap">
            <span class="text-xs text-gray-500 mr-1">快捷格式:</span>
            <button data-action="bold" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="粗体 (Ctrl+B)">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6V4zm0 8h9a4 4 0 014 4 4 4 0 01-4 4H6v-8z"/></svg>
            </button>
            <button data-action="italic" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="斜体 (Ctrl+I)">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            </button>
            <button data-action="heading" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="标题">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
            </button>
            <button data-action="link" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="链接">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </button>
            <button data-action="image" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="图片">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </button>
            <button data-action="code" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="代码">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            </button>
            <button data-action="quote" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="引用">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
            </button>
            <button data-action="list" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="列表">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
            </button>
            <button data-action="task" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="任务列表">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </button>
            <button data-action="table" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="表格">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7-8v8m14-8v8M3 10V6a2 2 0 012-2h14a2 2 0 012 2v4"/></svg>
            </button>
            <button data-action="hr" class="toolbar-btn p-1.5 rounded hover:bg-white/[0.08] transition-colors" title="分隔线">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
            </button>
          </div>

          <!-- Editor -->
          <div class="anime-card p-4">
            <div class="flex items-center justify-between mb-2">
              <label class="text-sm font-medium">Markdown 内容</label>
              <span id="word-count" class="text-xs text-gray-500">0 字符</span>
            </div>
            <textarea 
              id="editor" 
              class="w-full h-[500px] px-3 py-2 rounded-lg border border-white/10 bg-white/[0.03] text-sm font-mono focus:outline-none focus:border-purple-500/50 resize-none leading-relaxed"
              placeholder="在这里编辑 Markdown 内容..."
              spellcheck="false"
            ></textarea>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button id="btn-copy" class="flex-1 px-4 py-2 rounded-lg glass text-purple-300 hover:border-purple-400/40 transition-all text-sm font-medium flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              复制内容
            </button>
            <button id="btn-download" class="flex-1 px-4 py-2 rounded-lg glass text-gray-300 hover:bg-white/[0.08] transition-all text-sm font-medium flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              下载文件
            </button>
          </div>

          <!-- Instructions -->
          <div class="anime-card p-4 text-sm text-gray-400">
            <h4 class="font-medium text-gray-300 mb-2">使用说明</h4>
            <ol class="list-decimal list-inside space-y-1">
              <li>选择内容类型，会自动加载对应模板</li>
              <li>在编辑器中修改内容（左侧）</li>
              <li>右侧实时预览渲染效果</li>
              <li>点击"复制内容"复制到剪贴板</li>
              <li>或者点击"下载文件"保存为 .md 文件</li>
              <li>将文件放入对应的 src/content/ 目录</li>
              <li>提交到 GitHub 并推送</li>
            </ol>
          </div>
        </div>

        <!-- Preview Section -->
        <div class="anime-card p-4 flex flex-col h-full">
          <div class="flex items-center justify-between mb-4">
            <label class="text-sm font-medium">实时预览</label>
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-500">同步滚动</span>
              <button id="toggle-sync" class="w-8 h-4 rounded-full glass bg-purple-500/20 relative transition-colors">
                <span class="absolute left-0.5 top-0.5 w-3 h-3 rounded-full bg-purple-400 transition-transform"></span>
              </button>
            </div>
          </div>
          
          <!-- Frontmatter Info -->
          <div id="frontmatter-info" class="mb-4 p-3 rounded-lg glass text-xs hidden">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-gray-500">Frontmatter:</span>
              <span id="frontmatter-status" class="text-green-400">已检测</span>
            </div>
            <div id="frontmatter-fields" class="flex flex-wrap gap-1"></div>
          </div>
          
          <div id="preview" class="prose prose-invert prose-purple max-w-none text-sm overflow-y-auto flex-1 min-h-[500px] max-h-[700px] pr-2">
            <p class="text-gray-500">预览将在这里显示...</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ templates: JSON.stringify(templates) }}>
    const editor = document.getElementById('editor');
    const preview = document.getElementById('preview');
    const contentType = document.getElementById('content-type');
    const btnCopy = document.getElementById('btn-copy');
    const btnDownload = document.getElementById('btn-download');
    const wordCount = document.getElementById('word-count');
    const frontmatterInfo = document.getElementById('frontmatter-info');
    const frontmatterFields = document.getElementById('frontmatter-fields');
    const toggleSync = document.getElementById('toggle-sync');
    const templateData = JSON.parse(templates);
    
    let syncScroll = true;
    
    // Toggle sync scroll
    toggleSync.addEventListener('click', () => {
      syncScroll = !syncScroll;
      const dot = toggleSync.querySelector('span');
      if (syncScroll) {
        toggleSync.classList.add('glass', 'bg-purple-500/20');
        toggleSync.classList.remove('bg-gray-500/30');
        dot.style.transform = 'translateX(0)';
        dot.classList.add('bg-purple-400');
        dot.classList.remove('bg-gray-400');
      } else {
        toggleSync.classList.remove('glass', 'bg-purple-500/20');
        toggleSync.classList.add('bg-gray-500/30');
        dot.style.transform = 'translateX(16px)';
        dot.classList.remove('bg-purple-400');
        dot.classList.add('bg-gray-400');
      }
    });
    
    // Sync scroll
    editor.addEventListener('scroll', () => {
      if (!syncScroll) return;
      const ratio = editor.scrollTop / (editor.scrollHeight - editor.clientHeight);
      preview.scrollTop = ratio * (preview.scrollHeight - preview.clientHeight);
    });
    
    // Extract frontmatter
    function extractFrontmatter(md) {
      const match = md.match(/^---\n([\s\S]*?)\n---/);
      if (match) {
        const fields = [];
        const lines = match[1].split('\n');
        for (const line of lines) {
          const fieldMatch = line.match(/^([a-zA-Z0-9_]+):/);
          if (fieldMatch) {
            fields.push(fieldMatch[1]);
          }
        }
        return { exists: true, fields };
      }
      return { exists: false, fields: [] };
    }
    
    // Update frontmatter info
    function updateFrontmatterInfo(md) {
      const fm = extractFrontmatter(md);
      if (fm.exists) {
        frontmatterInfo.classList.remove('hidden');
        frontmatterFields.innerHTML = fm.fields.map(f => 
          `\u003cspan class="px-1.5 py-0.5 rounded glass-badge bg-purple-500/10 text-purple-300">${f}\u003c/span\u003e`
        ).join('');
      } else {
        frontmatterInfo.classList.add('hidden');
      }
    }
    
    // Advanced markdown to HTML converter
    function markdownToHtml(md) {
      // Extract and remove frontmatter
      let content = md.replace(/^---[\s\S]*?---\n?/, '');
      
      // Escape HTML
      content = content.replace(/\u003c/g, '\u0026lt;').replace(/\u003e/g, '\u0026gt;');
      
      // Code blocks (must be before inline code)
      content = content.replace(/```(\w+)?\n([\s\S]*?)```/g, (match, lang, code) => {
        const language = lang || 'text';
        const highlighted = highlightCode(code.trim(), language);
        return `\u003cpre class="bg-black/20 p-4 rounded-lg overflow-x-auto border border-white/5 mb-4"\u003e\u003ccode class="text-sm font-mono"\u003e${highlighted}\u003c/code\u003e\u003c/pre\u003e`;
      });
      
      // Inline code
      content = content.replace(/`([^`]+)`/g, '\u003ccode class="bg-white/10 px-1.5 py-0.5 rounded text-sm font-mono text-purple-300"\u003e$1\u003c/code\u003e');
      
      // Tables
      content = content.replace(/\|(.+)\|\n\|([-:\|\s]+)\|\n((?:\|.+\|\n?)+)/g, (match, header, separator, rows) => {
        const headers = header.split('|').map(h => h.trim()).filter(h => h);
        const aligns = separator.split('|').map(s => {
          if (s.trim().startsWith(':') && s.trim().endsWith(':')) return 'center';
          if (s.trim().endsWith(':')) return 'right';
          return 'left';
        }).filter(a => a);
        
        let html = '\u003ctable class="w-full border-collapse mb-4"\u003e\u003cthead\u003e\u003ctr\u003e';
        headers.forEach((h, i) => {
          const align = aligns[i] || 'left';
          html += `\u003cth class="border border-white/10 px-3 py-2 text-left font-medium bg-white/[0.03] text-purple-300" style="text-align: ${align}"\u003e${h}\u003c/th\u003e`;
        });
        html += '\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e';
        
        rows.trim().split('\n').forEach(row => {
          const cells = row.split('|').map(c => c.trim()).filter(c => c);
          html += '\u003ctr\u003e';
          cells.forEach((c, i) => {
            const align = aligns[i] || 'left';
            html += `\u003ctd class="border border-white/10 px-3 py-2" style="text-align: ${align}"\u003e${c}\u003c/td\u003e`;
          });
          html += '\u003c/tr\u003e';
        });
        
        html += '\u003c/tbody\u003e\u003c/table\u003e';
        return html;
      });
      
      // Task lists
      content = content.replace(/^\s*- \[x\]\s+(.+)$/gim, '\u003cli class="flex items-center gap-2 list-none"\u003e\u003cinput type="checkbox" checked disabled class="accent-purple-500"\u003e \u003cspan class="line-through opacity-50"\u003e$1\u003c/span\u003e\u003c/li\u003e');
      content = content.replace(/^\s*- \[ \]\s+(.+)$/gim, '\u003cli class="flex items-center gap-2 list-none"\u003e\u003cinput type="checkbox" disabled class="accent-purple-500"\u003e \u003cspan\u003e$1\u003c/span\u003e\u003c/li\u003e');
      
      // Headers
      content = content.replace(/^#### (.*$)/gim, '\u003ch4 class="text-lg font-semibold mt-6 mb-3 text-purple-300"\u003e$1\u003c/h4\u003e');
      content = content.replace(/^### (.*$)/gim, '\u003ch3 class="text-xl font-semibold mt-6 mb-3 text-purple-300"\u003e$1\u003c/h3\u003e');
      content = content.replace(/^## (.*$)/gim, '\u003ch2 class="text-2xl font-bold mt-8 mb-4 text-purple-300 border-b border-white/10 pb-2"\u003e$1\u003c/h2\u003e');
      content = content.replace(/^# (.*$)/gim, '\u003ch1 class="text-3xl font-bold mt-8 mb-4 text-purple-300"\u003e$1\u003c/h1\u003e');
      
      // Horizontal rules
      content = content.replace(/^---+$/gim, '\u003chr class="border-white/10 my-6"\u003e');
      
      // Blockquotes
      content = content.replace(/^\u003e\s+(.+)$/gim, '\u003cblockquote class="border-l-4 border-purple-500/50 pl-4 py-2 my-4 bg-white/[0.03] rounded-r-lg"\u003e\u003cp class="m-0 italic text-gray-300"\u003e$1\u003c/p\u003e\u003c/blockquote\u003e');
      
      // Ordered lists
      content = content.replace(/^\d+\.\s+(.+)$/gim, '\u003cli class="ml-4"\u003e$1\u003c/li\u003e');
      
      // Unordered lists (remaining)
      content = content.replace(/^\s*[-*]\s+(.+)$/gim, '\u003cli class="ml-4"\u003e$1\u003c/li\u003e');
      
      // Wrap consecutive list items
      content = content.replace(/(\u003cli[^\u003e]*\u003e.*\u003c\/li\u003e\n?)+/g, (match) => {
        if (match.includes('type="checkbox"')) {
          return `\u003cul class="space-y-1 my-4"\u003e${match}\u003c/ul\u003e`;
        }
        return `\u003cul class="list-disc list-inside space-y-1 my-4 text-gray-300"\u003e${match}\u003c/ul\u003e`;
      });
      
      // Bold and italic
      content = content.replace(/\*\*\*(.+?)\*\*\*/g, '\u003cstrong\u003e\u003cem\u003e$1\u003c/em\u003e\u003c/strong\u003e');
      content = content.replace(/\*\*(.+?)\*\*/g, '\u003cstrong class="text-white"\u003e$1\u003c/strong\u003e');
      content = content.replace(/\*(.+?)\*/g, '\u003cem class="text-gray-300"\u003e$1\u003c/em\u003e');
      content = content.replace(/~~(.+?)~~/g, '\u003cdel class="opacity-50"\u003e$1\u003c/del\u003e');
      
      // Links
      content = content.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '\u003ca href="$2" class="text-purple-400 hover:text-purple-300 hover:underline transition-colors" target="_blank"\u003e$1\u003c/a\u003e');
      
      // Images
      content = content.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '\u003cimg src="$2" alt="$1" class="rounded-lg max-w-full h-auto my-4 border border-white/10" loading="lazy"\u003e');
      
      // Line breaks
      content = content.replace(/\n/g, '\u003cbr\u003e');
      
      // Wrap in paragraphs (if not already wrapped)
      const segments = content.split('\u003cbr\u003e\u003cbr\u003e');
      content = segments.map(seg => {
        if (seg.trim() && !seg.trim().startsWith('\u003c')) {
          return `\u003cp class="my-2 leading-relaxed text-gray-300"\u003e${seg}\u003c/p\u003e`;
        }
        return seg;
      }).join('\u003cbr\u003e\u003cbr\u003e');
      
      return content;
    }
    
    // Simple syntax highlighting
    function highlightCode(code, language) {
      // Escape HTML
      let highlighted = code.replace(/\u003c/g, '\u0026lt;').replace(/\u003e/g, '\u0026gt;');
      
      // Comments
      highlighted = highlighted.replace(/(\/\/.*$)/gm, '\u003cspan class="text-gray-500"\u003e$1\u003c/span\u003e');
      highlighted = highlighted.replace(/(\/\*[\s\S]*?\*\/)/g, '\u003cspan class="text-gray-500"\u003e$1\u003c/span\u003e');
      
      // Strings
      highlighted = highlighted.replace(/(".*?")/g, '\u003cspan class="text-green-400"\u003e$1\u003c/span\u003e');
      highlighted = highlighted.replace(/('.*?')/g, '\u003cspan class="text-green-400"\u003e$1\u003c/span\u003e');
      
      // Keywords
      const keywords = ['function', 'const', 'let', 'var', 'if', 'else', 'for', 'while', 'return', 'class', 'import', 'export', 'from', 'async', 'await', 'new', 'this', 'true', 'false', 'null', 'undefined'];
      keywords.forEach(kw => {
        const regex = new RegExp(`\\b(${kw})\\b`, 'g');
        highlighted = highlighted.replace(regex, '\u003cspan class="text-purple-400"\u003e$1\u003c/span\u003e');
      });
      
      // Numbers
      highlighted = highlighted.replace(/\b(\d+)\b/g, '\u003cspan class="text-orange-400"\u003e$1\u003c/span\u003e');
      
      return highlighted;
    }
    
    // Update preview
    function updatePreview() {
      const md = editor.value;
      preview.innerHTML = markdownToHtml(md);
      updateFrontmatterInfo(md);
      
      // Update word count
      const count = md.length;
      wordCount.textContent = `${count} 字符`;
    }
    
    // Toolbar actions
    document.querySelectorAll('.toolbar-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        const start = editor.selectionStart;
        const end = editor.selectionEnd;
        const selected = editor.value.substring(start, end);
        let replacement = '';
        
        switch (action) {
          case 'bold':
            replacement = `**${selected || '粗体文本'}**`;
            break;
          case 'italic':
            replacement = `*${selected || '斜体文本'}*`;
            break;
          case 'heading':
            replacement = `\n## ${selected || '标题'}\n`;
            break;
          case 'link':
            replacement = `[${selected || '链接文字'}](https://example.com)`;
            break;
          case 'image':
            replacement = `![${selected || '图片描述'}](/images/example.jpg)`;
            break;
          case 'code':
            if (selected.includes('\n')) {
              replacement = `\n\`\`\`\n${selected || '代码块'}\n\`\`\`\n`;
            } else {
              replacement = `\`${selected || '代码'}\``;
            }
            break;
          case 'quote':
            replacement = `\n> ${selected || '引用内容'}\n`;
            break;
          case 'list':
            replacement = `\n- ${selected || '列表项'}\n- 列表项\n- 列表项\n`;
            break;
          case 'task':
            replacement = `\n- [ ] ${selected || '待办任务'}\n- [ ] 待办任务\n`;
            break;
          case 'table':
            replacement = `\n| 表头1 | 表头2 | 表头3 |\n|------|------|------|\n| 内容1 | 内容2 | 内容3 |\n`;
            break;
          case 'hr':
            replacement = `\n---\n`;
            break;
        }
        
        editor.value = editor.value.substring(0, start) + replacement + editor.value.substring(end);
        editor.focus();
        updatePreview();
      });
    });
    
    // Keyboard shortcuts
    editor.addEventListener('keydown', (e) => {
      if (e.ctrlKey || e.metaKey) {
        switch (e.key) {
          case 'b':
            e.preventDefault();
            document.querySelector('[data-action="bold"]')?.click();
            break;
          case 'i':
            e.preventDefault();
            document.querySelector('[data-action="italic"]')?.click();
            break;
        }
      }
    });
    
    editor.addEventListener('input', updatePreview);
    
    // Change template
    contentType.addEventListener('change', () => {
      const type = contentType.value;
      editor.value = templateData[type] || '';
      updatePreview();
    });
    
    // Copy to clipboard
    btnCopy.addEventListener('click', () => {
      navigator.clipboard.writeText(editor.value).then(() => {
        btnCopy.innerHTML = `
          \u003csvg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"\u003e
            \u003cpath stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /\u003e
          \u003c/svg\u003e
          已复制
        `;
        setTimeout(() => {
          btnCopy.innerHTML = `
            \u003csvg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"\u003e
              \u003cpath stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /\u003e
            \u003c/svg\u003e
            复制内容
          `;
        }, 2000);
      });
    });
    
    // Download file
    btnDownload.addEventListener('click', () => {
      const type = contentType.value;
      const blob = new Blob([editor.value], { type: 'text/markdown' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const date = new Date().toISOString().split('T')[0];
      a.href = url;
      a.download = `${date}-${type}.md`;
      a.click();
      URL.revokeObjectURL(url);
    });
    
    // Initialize with default template
    editor.value = templateData.work;
    updatePreview();
  </script>

