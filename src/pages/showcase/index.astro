---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/ui';

const lang = 'zh';
const t = useTranslations(lang as any);

const showcases = await getCollection('showcase');

// Sort showcases by season
const sortedShowcases = showcases.sort((a, b) => {
  const aYear = parseInt(a.data.season.slice(0, 4));
  const bYear = parseInt(b.data.season.slice(0, 4));
  if (aYear !== bYear) return bYear - aYear;
  
  const seasonOrder: Record<string, number> = { '冬': 0, '春': 1, '夏': 2, '秋': 3 };
  const aSeason = a.data.season.slice(4);
  const bSeason = b.data.season.slice(4);
  return (seasonOrder[bSeason] || 0) - (seasonOrder[aSeason] || 0);
});

const currentSeason = sortedShowcases[0];
---

<Layout title={t('showcase.title')} lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page Header -->
      <div class="mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold mb-2">{t('showcase.title')}</h1>
          <p class="text-muted">自动跟踪本季番剧制作进度</p>
        </div>
        
        <!-- Season Switcher -->
        {sortedShowcases.length > 0 && (
          <div class="flex items-center gap-2 overflow-x-auto max-w-full pb-2">
            {sortedShowcases.map(showcase => (
              <button 
                class="px-4 py-2 rounded-full text-sm font-medium transition-all whitespace-nowrap season-btn"
                data-season={showcase.data.season}
              >
                {showcase.data.season}
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Showcase Content -->
      {sortedShowcases.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-6xl mb-4">📋</div>
          <h2 class="text-xl font-semibold mb-2">暂无展示板数据</h2>
          <p class="text-muted">请通过管理后台添加季度计划</p>
        </div>
      ) : (
        sortedShowcases.map(showcase => (
          <div 
            class="season-content" 
            data-season={showcase.data.season}
            style={showcase !== currentSeason ? 'display: none;' : ''}
          >
            <div class="grid gap-6">
              {showcase.data.shows.map(show => {
                // Calculate max episodes from versions if available
                const maxEpisode = Math.max(...show.versions.map(v => Math.max(...(v.episodes || [0]), 0)), 12);
                const totalEpisodes = show.versions.reduce((acc, v) => acc + (v.episodes?.length || 0), 0);
                const avgCompleted = totalEpisodes / (show.versions.length || 1);
                const progress = Math.min((avgCompleted / maxEpisode) * 100, 100);
                
                return (
                  <div class="anime-card p-6">
                    <div class="flex items-start justify-between mb-4">
                      <div class="flex-1 min-w-0">
                        <h3 class="text-xl font-bold mb-1 truncate">{show.title}</h3>
                        <p class="text-sm text-muted">正则: <code class="bg-purple-500/10 px-2 py-0.5 rounded text-xs">{show.regex}</code></p>
                      </div>
                      <div class="text-right flex-shrink-0 ml-4">
                        <span class="text-2xl font-bold gradient-text">{Math.round(progress)}%</span>
                        <p class="text-xs text-muted">已完成</p>
                      </div>
                    </div>
                    
                    <!-- Progress Bar -->
                    <div class="w-full h-2 rounded-full bg-white/5 mb-6 overflow-hidden">
                      <div 
                        class="h-full rounded-full bg-gradient-to-r from-purple-500 to-pink-500 transition-all duration-1000"
                        style={`width: ${progress}%`}
                      ></div>
                    </div>
                    
                    <!-- Versions & Episodes -->
                    <div class="space-y-4">
                      {show.versions.map(version => (
                        <div class="border-t border-theme pt-4">
                          <h4 class="text-sm font-medium text-purple-400 mb-3 flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-purple-500"></span>
                            {version.name} 版
                          </h4>
                          
                          <div class="grid grid-cols-6 sm:grid-cols-8 md:grid-cols-12 gap-2">
                            {Array.from({ length: maxEpisode }, (_, i) => i + 1).map(ep => {
                              const isDone = (version.episodes || []).includes(ep);
                              return (
                                <div 
                                  class={`aspect-square rounded-lg flex items-center justify-center text-xs font-bold transition-all ${
                                    isDone 
                                      ? 'episode-done' 
                                      : 'episode-pending'
                                  }`}
                                >
                                  {ep}
                                </div>
                              );
                            })}
                          </div>
                          
                          <div class="flex items-center gap-4 mt-3 text-sm text-muted">
                            <span>已完成: {(version.episodes || []).length} / {maxEpisode} 集</span>
                            {(version.episodes || []).length > 0 && (
                              <span>最新: 第 {Math.max(...(version.episodes || [0]))} 集</span>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                    
                    {show.alsoIn && show.alsoIn.length > 0 && (
                      <div class="mt-4 pt-4 border-t border-theme text-sm text-muted">
                        同时出现在: {show.alsoIn.join(', ')}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        ))
      )}
    </div>
  </main>

  <script is:inline>
    document.querySelectorAll('.season-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const season = btn.dataset.season;
        
        // Update active state
        document.querySelectorAll('.season-btn').forEach(b => {
          b.style.background = '';
          b.style.color = '';
        });
        btn.style.background = 'linear-gradient(135deg, #c084fc 0%, #f472b6 100%)';
        btn.style.color = 'white';
        
        // Show/hide season content
        document.querySelectorAll('.season-content').forEach(content => {
          if (content.dataset.season === season) {
            content.style.display = '';
          } else {
            content.style.display = 'none';
          }
        });
      });
    });
    
    // Set initial active
    const firstBtn = document.querySelector('.season-btn');
    if (firstBtn) {
      firstBtn.style.background = 'linear-gradient(135deg, #c084fc 0%, #f472b6 100%)';
      firstBtn.style.color = 'white';
    }
  </script>

  <Footer lang={lang} />
</Layout>
