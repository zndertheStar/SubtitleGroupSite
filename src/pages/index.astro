---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/ui';

const lang = 'zh';
const t = useTranslations(lang);

const allWorks = await getCollection('works');
const allMisc = await getCollection('misc');

// 最新作品（用于 marquee 和列表）
const latestWorks = allWorks
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

// Marquee 展示前 8 个
const marqueeWorks = latestWorks.slice(0, 8);

const latestMisc = allMisc
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout title={t('home.hero.title')} description={t('home.hero.subtitle')} lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1">
    <!-- Marquee Banner -->
    {marqueeWorks.length > 0 && (
      <section class="relative overflow-hidden py-6">
        <div class="marquee-container flex" style="width: max-content;">
          {/* First set */}
          {marqueeWorks.map(work => (
            <a href={`/works/${work.id}`} class="marquee-item flex-shrink-0 mx-2 group">
              <div class="relative w-36 sm:w-44 aspect-[3/4] rounded-xl overflow-hidden shadow-lg border border-white/10">
                {work.data.cover ? (
                  <img 
                    src={work.data.cover} 
                    alt={work.data.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="eager"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-900/50 to-accent-900/50">
                    <span class="text-3xl">🎬</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute bottom-0 left-0 right-0 p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <p class="text-xs text-white font-medium truncate">{work.data.title}</p>
                </div>
              </div>
            </a>
          ))}
          {/* Duplicate set for seamless loop */}
          {marqueeWorks.map(work => (
            <a href={`/works/${work.id}`} class="marquee-item flex-shrink-0 mx-2 group">
              <div class="relative w-36 sm:w-44 aspect-[3/4] rounded-xl overflow-hidden shadow-lg border border-white/10">
                {work.data.cover ? (
                  <img 
                    src={work.data.cover} 
                    alt={work.data.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="eager"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-900/50 to-accent-900/50">
                    <span class="text-3xl">🎬</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute bottom-0 left-0 right-0 p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <p class="text-xs text-white font-medium truncate">{work.data.title}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Left Column: Latest Works -->
        <div class="flex-1">
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span class="w-1 h-6 rounded-full bg-gradient-to-b from-primary-500 to-accent-500"></span>
            {t('home.latest')}
          </h2>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
            {latestWorks.map(work => (
              <a href={`/works/${work.id}`} class="anime-card group block">
                <div class="aspect-[3/4] bg-gradient-to-br from-primary-900/50 to-accent-900/50 flex items-center justify-center overflow-hidden relative">
                  {work.data.cover ? (
                    <img 
                      src={work.data.cover} 
                      alt={work.data.title} 
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-4xl">🎬</span>
                  )}
                  
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
                  
                  <div class="glass-badge absolute top-2 right-2 px-1.5 py-0.5 rounded text-[10px] font-medium text-white">
                    {work.data.category === 'anime' ? '动画' : work.data.category === 'movie' ? '电影' : work.data.category === 'ova' ? 'OVA' : '其他'}
                  </div>
                  
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <h3 class="font-semibold text-sm text-white group-hover:text-primary-300 transition-colors truncate">{work.data.title}</h3>
                    <div class="flex items-center justify-between mt-1">
                      <span class="text-[10px] text-gray-400">{work.data.pubDate.toLocaleDateString('zh-CN')}</span>
                      {work.data.episode && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full glass text-primary-200">第{work.data.episode}集</span>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Right Column: Latest Misc -->
        {latestMisc.length > 0 && (
          <div class="lg:w-80 flex-shrink-0">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
              <span class="w-1 h-6 rounded-full bg-gradient-to-b from-blue-500 to-cyan-500"></span>
              杂谈
            </h2>
            
            <div class="space-y-3">
              {latestMisc.map(post => (
                <a href={`/misc/${post.id}`} class="anime-card block p-4 transition-all group">
                  <h3 class="font-semibold text-sm group-hover:text-primary-400 transition-colors line-clamp-2">{post.data.title}</h3>
                  <p class="text-xs text-gray-500 mt-1.5 line-clamp-2">{post.data.description}</p>
                  <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray-500">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </main>

  <style is:inline>
    @keyframes marquee-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .marquee-container {
      animation: marquee-scroll 40s linear infinite;
    }
    .marquee-container:hover {
      animation-play-state: paused;
    }
  </style>

  <Footer lang={lang} />
</Layout>
