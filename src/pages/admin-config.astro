---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'zh';
---

<Layout title="站点配置" description="修改站点配置" lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-1">站点配置</h1>
          <p class="text-sm text-gray-400">修改站点名称、图标等基本信息</p>
        </div>
        <a href="/admin-dashboard" class="text-sm text-purple-400 hover:text-purple-300">← 返回管理后台</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1 space-y-4">
          <div class="anime-card p-4">
            <h3 class="font-semibold mb-3">配置文件位置</h3>
            <div class="text-sm text-gray-400 space-y-1">
              <p>站点配置：</p>
              <code class="block bg-white/5 p-2 rounded text-xs">src/config/site.ts</code>
              <p class="mt-2">友站链接：</p>
              <code class="block bg-white/5 p-2 rounded text-xs">src/config/friends.ts</code>
            </div>
          </div>

          <div class="anime-card p-4">
            <h3 class="font-semibold mb-3">图标位置</h3>
            <div class="text-sm text-gray-400 space-y-1">
              <p>SVG 图标：</p>
              <code class="block bg-white/5 p-2 rounded text-xs">public/favicon.svg</code>
              <p class="mt-2">ICO 图标：</p>
              <code class="block bg-white/5 p-2 rounded text-xs">public/favicon.ico</code>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="anime-card p-4">
            <div class="flex items-center justify-between mb-4">
              <label class="text-sm font-medium">site.ts 配置模板</label>
              <button id="btn-copy" class="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                复制
              </button>
            </div>
            <textarea 
              id="template-editor" 
              class="w-full h-[500px] px-3 py-2 rounded-lg border border-white/10 bg-white/5 text-sm font-mono focus:outline-none focus:border-purple-500/50 resize-none"
              readonly
            ></textarea>
          </div>

          <div class="anime-card p-4 mt-4">
            <h3 class="font-semibold mb-3">配置项说明</h3>
            <dl class="text-sm text-gray-400 space-y-2">
              <div>
                <dt class="font-medium text-gray-300">name / nameEn / nameJa</dt>
                <dd>站点名称（中文/英文/日文）</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-300">description</dt>
                <dd>站点描述，显示在首页和 SEO 中</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-300">logo.iconText</dt>
                <dd>Logo 文字，如 "G" 或 "绿"</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-300">url</dt>
                <dd>站点完整 URL，用于生成 RSS 和 OG 图片</dd>
              </div>
              <div>
                <dt class="font-medium text-gray-300">copyright</dt>
                <dd>版权后缀，如 "用爱发电"</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    // 设置模板内容
    const templateContent = `// 站点配置文件\n// 修改这里即可更改站点名称、图标等信息\n\nexport const siteConfig = {\n  // 站点名称（支持多语言）\n  name: '绿茶字幕组',\n  nameEn: 'Green Tea Subs',\n  nameJa: '緑茶字幕組',\n  \n  // 站点描述\n  description: '用心翻译每一帧',\n  descriptionEn: 'Translating every frame with heart',\n  descriptionJa: '一つ一つのフレームに心を込めて',\n  \n  // 站点图标（存放在 public 目录下）\n  favicon: {\n    svg: '/favicon.svg',\n    ico: '/favicon.ico',\n  },\n  \n  // Logo 配置\n  logo: {\n    // 是否使用文字 Logo（如果为 false，将使用图标）\n    text: true,\n    // 图标文字（单个字母或短文字）\n    iconText: 'G',\n    // 如果使用图片 Logo，填写图片路径\n    image: '',\n  },\n  \n  // 站点 URL\n  url: 'https://green-tea-subs.vercel.app',\n  \n  // 版权信息\n  copyright: '用爱发电',\n  copyrightEn: 'Powered by Love',\n  copyrightJa: '愛で動く',\n};`;
    
    document.getElementById('template-editor').value = templateContent;
    
    document.getElementById('btn-copy')?.addEventListener('click', () => {
      const editor = document.getElementById('template-editor');
      navigator.clipboard.writeText(editor.value).then(() => {
        const btn = document.getElementById('btn-copy');
        btn.textContent = '已复制';
        setTimeout(() => {
          btn.innerHTML = `
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            复制
          `;
        }, 2000);
      });
    });
  </script>

  <Footer lang={lang} />
</Layout>
