---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig, getSiteName } from '../config/site';

const lang = 'zh';
const siteName = getSiteName(lang);
const aboutData = await getCollection('about');
const about = aboutData[0];
let Content;
if (about) {
  const rendered = await render(about);
  Content = rendered.Content;
}
---

<Layout title="关于我们" lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-3xl mb-6 glow-purple">
          {siteConfig.logo.iconText}
        </div>
        <h1 class="text-4xl font-bold mb-4 gradient-text">{siteName}</h1>
        <p class="text-xl text-gray-400">{siteConfig.nameEn}</p>
      </div>

      {Content ? (
        <article class="prose prose-invert prose-purple max-w-none">
          <Content />
        </article>
      ) : (
        <div class="text-center text-gray-500 py-12">
          关于页面内容尚未编辑，请通过管理后台添加内容。
          <br />
          <a href="/admin" class="text-purple-400 hover:text-purple-300 mt-4 inline-block">前往后台编辑</a>
        </div>
      )}

      <!-- Team Members Section -->
      <section class="mt-12 pt-12 border-t" style="border-color: rgba(45, 27, 78, 0.5);">
        <h2 class="text-2xl font-bold mb-6">核心成员</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <!-- Placeholder - will be populated from about page frontmatter or manual config -->
          <div class="anime-card p-4 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-purple-500/30 to-pink-500/30 flex items-center justify-center mb-3">
              <span class="text-2xl">👤</span>
            </div>
            <div class="font-medium">组长</div>
            <div class="text-sm text-gray-500">统筹管理</div>
          </div>
          <div class="anime-card p-4 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-purple-500/30 to-pink-500/30 flex items-center justify-center mb-3">
              <span class="text-2xl">✍️</span>
            </div>
            <div class="font-medium">翻译组</div>
            <div class="text-sm text-gray-500">翻译/校对</div>
          </div>
          <div class="anime-card p-4 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-purple-500/30 to-pink-500/30 flex items-center justify-center mb-3">
              <span class="text-2xl">🎨</span>
            </div>
            <div class="font-medium">后期组</div>
            <div class="text-sm text-gray-500">压制/特效</div>
          </div>
          <div class="anime-card p-4 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-purple-500/30 to-pink-500/30 flex items-center justify-center mb-3">
              <span class="text-2xl">💻</span>
            </div>
            <div class="font-medium">技术组</div>
            <div class="text-sm text-gray-500">网站/工具</div>
          </div>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="mt-12 pt-12 border-t" style="border-color: rgba(45, 27, 78, 0.5);">
        <h2 class="text-2xl font-bold mb-6">加入我们</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="anime-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-green-500/20 to-emerald-500/20 flex items-center justify-center">
              <span class="text-xl">📱</span>
            </div>
            <div>
              <div class="font-medium">QQ 群</div>
              <div class="text-sm text-gray-500">加入粉丝群获取最新动态</div>
            </div>
          </div>
          <div class="anime-card p-4 flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center">
              <span class="text-xl">🐙</span>
            </div>
            <div>
              <div class="font-medium">GitHub</div>
              <div class="text-sm text-gray-500">开源项目与字幕归档</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
