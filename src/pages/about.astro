---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig, getSiteName } from '../config/site';

const lang = 'zh';
const siteName = getSiteName(lang);
const aboutData = await getCollection('about');
const about = aboutData[0];
let Content;
if (about) {
  const rendered = await render(about);
  Content = rendered.Content;
}
---

<Layout title="关于我们" lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        {siteConfig.logo.image ? (
          <img src={siteConfig.logo.image} alt={siteName} class="w-20 h-20 mx-auto rounded-2xl mb-6" />
        ) : (
          <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-3xl mb-6 glow-purple">
            {siteConfig.logo.iconText}
          </div>
        )}
        <h1 class="text-4xl font-bold mb-4 gradient-text">{siteName}</h1>
        <p class="text-xl text-gray-400">{siteConfig.nameEn}</p>
      </div>

      {Content ? (
        <article class="prose prose-invert prose-purple max-w-none">
          <Content />
        </article>
      ) : (
        <div class="text-center text-gray-500 py-12">
          关于页面内容尚未编辑，请通过管理后台添加内容。
          <br />
          <a href="/admin" class="text-purple-400 hover:text-purple-300 mt-4 inline-block">前往后台编辑</a>
        </div>
      )}

      {about?.data?.members && about.data.members.length > 0 && (
        <section class="mt-12 pt-12 border-t" style="border-color: rgba(45, 27, 78, 0.5);">
          <h2 class="text-2xl font-bold mb-6">核心成员</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {about.data.members.map((member) => (
              <div class="anime-card p-4 text-center">
                {member.icon && (
                  <div class="w-16 h-16 mx-auto rounded-full glass bg-purple-500/10 flex items-center justify-center mb-3">
                    <span class="text-2xl">{member.icon}</span>
                  </div>
                )}
                <div class="font-medium">{member.name}</div>
                {member.role && <div class="text-sm text-gray-500">{member.role}</div>}
              </div>
            ))}
          </div>
        </section>
      )}

      {about?.data?.contacts && about.data.contacts.length > 0 && (
        <section class="mt-12 pt-12 border-t" style="border-color: rgba(45, 27, 78, 0.5);">
          <h2 class="text-2xl font-bold mb-6">加入我们</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {about.data.contacts.map((contact) => {
              const Wrapper = contact.url ? 'a' : 'div';
              return (
                <Wrapper
                  href={contact.url}
                  target={contact.url ? '_blank' : undefined}
                  class={`anime-card p-4 flex items-center gap-4 ${contact.url ? 'hover:border-purple-500/30 transition-colors cursor-pointer' : ''}`}
                >
                  {contact.icon && (
                    <div class="w-12 h-12 rounded-lg glass bg-green-500/10 flex items-center justify-center flex-shrink-0">
                      {contact.icon.endsWith('.png') || contact.icon.endsWith('.svg') || contact.icon.endsWith('.jpg') ? (
                        <img src={contact.icon} alt={contact.name} class="w-7 h-7 object-contain" />
                      ) : (
                        <span class="text-xl">{contact.icon}</span>
                      )}
                    </div>
                  )}
                  <div>
                    <div class="font-medium">{contact.name}</div>
                    {contact.description && <div class="text-sm text-gray-500">{contact.description}</div>}
                  </div>
                </Wrapper>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
