---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { friendLinks } from '../config/friends';

const lang = 'zh';
---

<Layout title="友站链接" description="友情链接" lang={lang}>
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold mb-3">友站链接</h1>
        <p class="text-gray-400">这里是我们推荐的友站，欢迎访问</p>
      </div>

      {friendLinks.length === 0 ? (
        <!-- Empty State -->
        <div class="text-center py-16">
          <div class="text-6xl mb-4">🔗</div>
          <h2 class="text-xl font-semibold mb-2">暂无友站链接</h2>
          <p class="text-gray-400 mb-6">请编辑 src/config/friends.ts 添加友站</p>
          
          <div class="max-w-lg mx-auto p-4 rounded-xl bg-white/5 border border-white/10 text-left">
            <p class="text-sm text-gray-300 mb-2">添加示例：</p>
            <pre class="text-xs text-gray-400 overflow-x-auto">{`export const friendLinks = [
  {
    name: '友站名称',
    url: 'https://example.com',
    description: '友站描述',
  },
];`}</pre>
          </div>
        </div>
      ) : (
        <!-- Friend Links Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {friendLinks.map(link => (
            <a 
              href={link.url} 
              target="_blank" 
              rel="noopener" 
              class="anime-card p-5 group hover:border-primary-500/30 transition-all"
            >
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500/20 to-accent-500/20 flex items-center justify-center flex-shrink-0">
                  <span class="text-2xl">🔗</span>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-lg group-hover:text-primary-400 transition-colors">{link.name}</h3>
                  {link.description && (
                    <p class="text-sm text-gray-400 mt-1">{link.description}</p>
                  )}
                  <div class="flex items-center gap-1 mt-2 text-xs text-gray-500">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    <span class="truncate">{link.url}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- Add Friend Link CTA -->
      <div class="mt-12 text-center p-6 rounded-xl border border-white/5 bg-white/[0.02]">
        <p class="text-sm text-gray-400">
          想要交换友链？请在 <code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">src/config/friends.ts</code> 中添加你的站点
        </p>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
