---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';

const lang = 'zh';
---

<Layout title="个人资料" description="用户个人资料" lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="anime-card p-8">
        <div class="text-center mb-8">
          <div id="profile-avatar" class="w-24 h-24 mx-auto rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-3xl font-bold mb-4">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h1 id="profile-name" class="text-2xl font-bold">未登录</h1>
          <p id="profile-email" class="text-gray-400 mt-1">请登录后查看个人资料</p>
        </div>

        <div id="profile-actions" class="space-y-3">
          <div class="space-y-2">
            <button id="profile-login-btn" class="w-full py-3 rounded-xl bg-purple-500/20 text-purple-300 hover:bg-purple-500/30 transition-all font-medium flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              使用 GitHub 登录
            </button>
          </div>
          
          <div class="text-center">
            <p class="text-sm text-gray-500">登录后可以在评论区发表留言</p>
          </div>
        </div>

        <div id="profile-info" class="hidden space-y-4">
          <div class="p-4 rounded-xl bg-white/5 border border-white/5">
            <h3 class="font-medium mb-2">账户信息</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-400">登录方式</span>
                <span class="text-purple-400">GitHub</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-400">用户ID</span>
                <span id="profile-id" class="text-gray-300">-</span>
              </div>
            </div>
          </div>
          
          <button id="profile-logout-btn" class="w-full py-3 rounded-xl bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-all font-medium">
            退出登录
          </button>
        </div>
      </div>

      <!-- Setup Guide -->
      <div class="mt-8 anime-card p-6">
        <h2 class="font-semibold mb-4">配置说明</h2>
        <div class="space-y-3 text-sm text-gray-400">
          <p>要使用 GitHub 登录功能，需要在 Netlify 中配置：</p>
          <ol class="list-decimal list-inside space-y-2">
            <li>访问 <a href="https://app.netlify.com" target="_blank" class="text-purple-400 hover:underline">Netlify 控制台</a></li>
            <li>进入站点设置 → Identity</li>
            <li>启用 Identity 服务</li>
            <li>在 External providers 中添加 GitHub</li>
            <li>配置 GitHub OAuth App 凭证</li>
          </ol>
          <p class="mt-4">配置完成后，用户即可使用 GitHub 账号登录并参与评论。</p>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (function() {
      const profileAvatar = document.getElementById('profile-avatar');
      const profileName = document.getElementById('profile-name');
      const profileEmail = document.getElementById('profile-email');
      const profileActions = document.getElementById('profile-actions');
      const profileInfo = document.getElementById('profile-info');
      const profileId = document.getElementById('profile-id');
      const loginBtn = document.getElementById('profile-login-btn');
      const logoutBtn = document.getElementById('profile-logout-btn');

      function updateProfile() {
        const user = netlifyIdentity?.currentUser();
        
        if (user) {
          profileName.textContent = user.user_metadata?.full_name || user.email?.split('@')[0] || '用户';
          profileEmail.textContent = user.email || '';
          profileId.textContent = user.id || '-';
          profileActions.classList.add('hidden');
          profileInfo.classList.remove('hidden');
          
          if (user.user_metadata?.avatar_url) {
            profileAvatar.innerHTML = `<img src="${user.user_metadata.avatar_url}" class="w-24 h-24 rounded-full object-cover" />`;
          } else {
            const initial = (user.user_metadata?.full_name || user.email || 'U')[0].toUpperCase();
            profileAvatar.innerHTML = `<span class="text-3xl font-bold">${initial}</span>`;
          }
        } else {
          profileName.textContent = '未登录';
          profileEmail.textContent = '请登录后查看个人资料';
          profileActions.classList.remove('hidden');
          profileInfo.classList.add('hidden');
          profileAvatar.innerHTML = `
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          `;
        }
      }

      loginBtn?.addEventListener('click', () => {
        netlifyIdentity?.open('login');
      });

      logoutBtn?.addEventListener('click', () => {
        netlifyIdentity?.logout();
      });

      if (window.netlifyIdentity) {
        netlifyIdentity.on('init', updateProfile);
        netlifyIdentity.on('login', updateProfile);
        netlifyIdentity.on('logout', updateProfile);
      }

      setTimeout(updateProfile, 1000);
    })();
  </script>

  <Footer lang={lang} />
</Layout>
