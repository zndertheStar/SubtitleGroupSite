---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';

const lang = 'zh';
---

<Layout title="个人资料" description="用户个人资料" lang={lang}>
  <PageLoader />
  <Header lang={lang} />
  
  <main class="flex-1 py-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="anime-card p-8">
        <div class="text-center mb-8">
          <div class="w-24 h-24 mx-auto rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-3xl font-bold mb-4">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold">个人资料</h1>
          <p class="text-gray-400 mt-1">此功能暂未启用</p>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
