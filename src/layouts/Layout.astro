---
import '../styles/global.css';
import { siteConfig, getSiteName } from '../config/site';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  image?: string;
}

const { 
  title, 
  description = `${getSiteName(Astro.props.lang)}官方网站`, 
  lang = 'zh',
  image = '/images/og-default.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {getSiteName(lang)}</title>
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={siteConfig.favicon.svg} />
  <link rel="alternate icon" type="image/x-icon" href={siteConfig.favicon.ico} />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.site)} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  
  <!-- Umami (replace with your Umami script URL) -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="4a14359d-5d54-4a9c-98aa-ec973ad6fa1e"></script>
  
  <!-- Dark mode init -->
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col relative">
  <!-- Random ACG Background -->
  <div id="bg-layer" class="fixed inset-0 z-[-1] transition-opacity duration-700">
    <div id="bg-image" class="absolute inset-0 bg-cover bg-center bg-no-repeat"></div>
    <div id="bg-overlay" class="absolute inset-0"></div>
  </div>
  
  <script is:inline>
    (function() {
      const bgImage = document.getElementById('bg-image');
      const bgOverlay = document.getElementById('bg-overlay');
      
      // Random image from loliapi
      const imgUrl = 'https://www.loliapi.com/acg/?t=' + Date.now();
      bgImage.style.backgroundImage = 'url(' + imgUrl + ')';
      
      // Apply overlay based on theme
      function applyOverlay() {
        const theme = document.documentElement.getAttribute('data-theme') || 'dark';
        if (theme === 'dark') {
          bgOverlay.style.background = 'rgba(15, 10, 30, 0.65)';
        } else {
          bgOverlay.style.background = 'rgba(250, 245, 255, 0.70)';
        }
      }
      
      applyOverlay();
      
      // Listen for theme changes
      const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
          if (mutation.attributeName === 'data-theme') {
            applyOverlay();
          }
        });
      });
      
      observer.observe(document.documentElement, { attributes: true });
    })();
  </script>
  
  <slot />
</body>
</html>
